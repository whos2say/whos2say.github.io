# Normalize line endings so Windows editors don't churn the repo on every commit.
# All text files stored with LF in the repo; checked out as LF.

* text=auto eol=lf

# Explicit rules for common text types (defensive)
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.mjs    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.svg    text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf

# Binary assets — never munged
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.pdf    binary
*.mp3    binary
*.mp4    binary
*.mov    binary
*.webm   binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
