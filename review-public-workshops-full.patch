+/* =========================================================
+   Creative Workshops Page (scoped) — reuses program/how-card styles
+   Adds: 4-up steps grid, rate price emphasis, note + centered CTA
+   ========================================================= */
+
+/* 4-up "How It Works" steps (how-grid stays 3-up elsewhere) */
+.how-grid--4{
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+}
+@media (max-width: 980px){
+  .how-grid--4{ grid-template-columns: 1fr 1fr; }
+}
+@media (max-width: 560px){
+  .how-grid--4{ grid-template-columns: 1fr; }
+}
+
+/* Rate emphasis inside reused .how-card
+   p.rate-price beats .how-card p on specificity ties (defined later, same 0,1,1) */
+p.rate-price,
+.rate-price{
+  margin: 0.35rem 0 0.4rem;
+  font-family: var(--font-heading);
+  font-size: 1.4rem;
+  font-weight: 800;
+  color: var(--color-primary);
+}
+
+/* Supporting note under rates / funding */
+.cw-note{
+  margin-top: 1rem;
+  color: var(--text-muted);
+  font-size: 0.95rem;
+}
+.cw-note a{ color: var(--color-primary); }
+
+/* Centered final CTA block */
+.cw-cta{ text-align: center; }
+.cw-cta .how-sub{ margin-left: auto; margin-right: auto; }
+.cw-cta .btn-row{ justify-content: center; }
