# =============================================================================
# Who's to Say Foundation — environment variables
# Copy to .env.local for local experiments. NEVER commit real secrets.
# Production: set these in Vercel → Project → Settings → Environment Variables
# =============================================================================

# --- Decap CMS / GitHub OAuth (required for /admin/ login on Vercel) ---
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Homepage URL:              https://whostosay.org
#   Authorization callback URL: https://whostosay.org/api/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must exactly match the Authorization callback URL in the GitHub OAuth App
OAUTH_REDIRECT_URI=https://whostosay.org/api/callback

# Public site origin (used if OAUTH_REDIRECT_URI is omitted)
SITE_ORIGIN=https://whostosay.org

# GitHub OAuth scope — repo write access for CMS commits (default: repo)
# GITHUB_OAUTH_SCOPE=repo

# --- Photo album / Supabase (existing — see PHOTO_ALBUM_README.md) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
