# =============================================================================
# Who's to Say Foundation — environment variables
# Copy to .env.local for local experiments. NEVER commit real secrets.
# Production: Vercel → Production env. Staging: Vercel → Preview, branch staging.
# =============================================================================

# --- Decap CMS / GitHub OAuth ---
# TWO GitHub OAuth Apps required (one callback URL per app).
# See docs/STAGING_WORKFLOW.md and docs/DECAP_PRODUCTION_CHECKLIST.md

# === PRODUCTION (main / www.whostosay.org) ===
# GitHub OAuth App:
#   Homepage URL:              https://www.whostosay.org
#   Authorization callback URL: https://www.whostosay.org/api/callback
DECAP_GIT_BRANCH=main
SITE_ORIGIN=https://www.whostosay.org
DECAP_SITE_DOMAIN=www.whostosay.org
OAUTH_REDIRECT_URI=https://www.whostosay.org/api/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === STAGING (staging branch / staging.whostosay.org) ===
# Separate GitHub OAuth App:
#   Homepage URL:              https://staging.whostosay.org
#   Authorization callback URL: https://staging.whostosay.org/api/callback
# DECAP_GIT_BRANCH=staging
# SITE_ORIGIN=https://staging.whostosay.org
# DECAP_SITE_DOMAIN=staging.whostosay.org
# OAUTH_REDIRECT_URI=https://staging.whostosay.org/api/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# GitHub OAuth scope — repo write access for CMS commits (default: repo)
# GITHUB_OAUTH_SCOPE=repo

# --- Photo album / Supabase (existing — see PHOTO_ALBUM_README.md) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Public class availability + signup (see docs/class-calendar-signup.md) ---
# Google Calendar ID for the classes calendar (e.g. abc123@group.calendar.google.com)
GOOGLE_CLASSES_CALENDAR_ID=
# Google API key with Calendar API read access (restricted to Calendar API, no Sheets)
GOOGLE_CALENDAR_API_KEY=
# Google Sheets spreadsheet ID for the Signups tab
GOOGLE_SIGNUPS_SHEET_ID=
# Service account credentials (needs Sheets Editor access on the signups spreadsheet)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full PEM private key from the service account JSON; Vercel stores as one line
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Default max seats per class session (must be <= 3 per program guidelines)
CLASS_DEFAULT_CAPACITY=3
