# Google Apps Script Web App (container-bound to your spreadsheet)
# Deploy apps-script/Code.gs from the spreadsheet → copy Web App /exec URL
RTD_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
RTD_API_SECRET=generate_a_long_random_secret_and_match_script_properties

# Optional: Resend for transactional email (if not set, mailto fallback is used)
RESEND_API_KEY=
RESEND_FROM_EMAIL=estimates@yourdomain.com

# App URL for print links in emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Vercel sets VERCEL_URL automatically in production (fallback for email print links)

# Optional site protection (server-only — NOT NEXT_PUBLIC)
# RTD_SITE_USER=crew
# RTD_SITE_PASSWORD=choose_a_strong_password
